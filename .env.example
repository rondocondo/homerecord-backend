# HomeRecord — copy to .env and fill in your values. Never commit .env to git.

PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://homerecord:yourpassword@localhost:5432/homerecord

# JWT Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
REPORT_PRICE_CENTS=3900

# Chicago Open Data (free — token optional, raises rate limit)
CHICAGO_APP_TOKEN=
CHICAGO_PERMITS_URL=https://data.cityofchicago.org/resource/ydr8-5enu.json
CHICAGO_VIOLATIONS_URL=https://data.cityofchicago.org/resource/22u3-xenr.json

# FEMA
FEMA_API_URL=https://www.fema.gov/api/open/v2

# CORS
FRONTEND_URL=http://localhost:3000

# AWS S3 (document uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=homerecord-documents
